{
  "compilerOptions": {
    "types": ["node"],
    "target": "ESNext",
    "lib": ["es5", "es6", "es7", "es2022", "dom"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "typeRoots": ["./types", "./node_modules/@types"],
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "./types"
  },
  "include": ["./src/**/*"],
  "exclude": ["tests", "./types/**/*"]
}
